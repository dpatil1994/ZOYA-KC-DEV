                                                    Please enter a valid email address
                                                </div>
                                            </div>
                                            
                                            <div class="slds-col slds-size_1-of-3 slds-p-horizontal_small">
                                                <label class="slds-form-element__label ">Company Alternate Email</label>
                                                <apex:inputField value="{!agency.Company_Alternate_Email_1__c}"
                                                                   styleClass="slds-input" onblur="validateEmail(this);"/>
                                                
                                                <div id="emailError"
                                                     class="slds-form-element__help slds-text-color_error"
                                                     style="display:none;">
                                                    Please enter a valid email address
                                                </div>
                                            </div>
                                            
                                            <div class="slds-col slds-size_1-of-3 slds-p-horizontal_small">
                                                <div class="slds-form-element">
                                                    <label class="slds-form-element__label required-label">
                                                        Company Phone
                                                    </label>
                                                    
                                                    <div class="slds-grid slds-gutters_small">
                                                        
                                                        <!-- Country Code -->
                                                        <div class="slds-col slds-size_1-of-3">
                                                            <apex:selectList value="{!agency.Country_Code__c}"
                                                                             styleClass="slds-select agent-required"
                                                                             size="1"
                                                                           >
                                                                <span class="error-message"></span>
                                                                <apex:selectOptions value="{!countryCodeOptions}" />
                                                            </apex:selectList>
                                                        </div>
                                                        
                                                        <!-- Phone Number -->
                                                      <div class="slds-col slds-size_2-of-3">
                                                        <apex:inputText value="{!agency.Company_Official_Phone_No__c}"
                                                                        styleClass="slds-input agent-required"
                                                                         onblur="validatePhone(this);"
                                                                          maxlength="12"/>
                                                    
                                                        <span class="error-message"></span>
                                                    
                                                        <div id="phoneError"
                                                             class="slds-form-element__help slds-text-color_error"
                                                             style="display:none;">
                                                            Please enter numbers only
                                                        </div>
                                                    </div>

                                                        
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            <div class="slds-col slds-size_1-of-3 slds-p-horizontal_small">
    <div class="slds-form-element">

        <label class="slds-form-element__label required-label">
            Zoya Development Sales Representative
        </label>

        <div class="slds-form-element__control">

            <apex:selectList value="{!agency.Sales_Representative__c}"
