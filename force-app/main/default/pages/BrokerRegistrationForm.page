        <script>

//////////////////// EMAIL ////////////////////
function validateEmail(input) {
    var emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    var errorDiv = document.getElementById('emailError');

    if (input.value && !emailRegex.test(input.value)) {
        errorDiv.style.display = 'block';
        input.classList.add('slds-has-error');
    } else {
        errorDiv.style.display = 'none';
        input.classList.remove('slds-has-error');
    }
}

//////////////////// BANK ////////////////////
function toggleBankSection(value) {
    const section = document.querySelector('.bank-section');
    const fields = document.querySelectorAll('.bank-required');

    if (!section) return;

    if (value === 'Available') {
        section.style.display = 'block';
        fields.forEach(f => f.setAttribute('required', 'true'));
    } else {
        section.style.display = 'none';
        fields.forEach(f => f.removeAttribute('required'));
    }
}

document.addEventListener("DOMContentLoaded", function () {

    const select = document.querySelector("[name$='Bank_Document_Available__c']");
    if (select) toggleBankSection(select.value);

    // 🔥 important delay for VF binding
    setTimeout(function () {
        const accType = document.querySelector("[name$='Type__c']");
        if (accType && accType.value) {
            toggleAccountFields(accType.value);
        }
    }, 300);

});

//////////////////// PARTNERS ////////////////////
function togglePartners(value) {
    const section = document.getElementById('partnerSection');
    const fields = document.querySelectorAll('.partner-required');

    if (value === 'Partnership') {
        section.style.display = 'block';
        fields.forEach(f => f.setAttribute('required', 'true'));
    } else {
        section.style.display = 'none';
        fields.forEach(f => f.removeAttribute('required'));
    }
}

//////////////////// TRN ////////////////////
function toggleTRN(value) {
    const section = document.getElementById('trnSection');
    const fields = document.querySelectorAll('.trn-required');

    if (value === 'Yes') {
        section.style.display = 'block';
        fields.forEach(f => f.setAttribute('required', 'true'));
    } else {
        section.style.display = 'none';
        fields.forEach(f => f.removeAttribute('required'));
    }
}

document.addEventListener("DOMContentLoaded", function () {
    const ownership = document.querySelector("[name$='OwnerShip__c']");
    const trn = document.querySelector("[name$='Have_TRN__c']");

    if (ownership) togglePartners(ownership.value);
    if (trn) toggleTRN(trn.value);
});

//////////////////// RERA ////////////////////
document.addEventListener("DOMContentLoaded", function () {
    const subtype = document.querySelector("[name$='Sub_Type__c']");
    if (subtype) toggleReraFields(subtype.value);
});

function toggleReraFields(value) {
    const sections = document.querySelectorAll(".rera-section");
    if (!sections) return;

    const show = value === "Dubai Real Estate Company (RERA Registered)";
    sections.forEach(sec => {
        sec.style.display = show ? "block" : "none";
    });
}

//////////////////// INDIVIDUAL TYPE ////////////////////
function handleIndividualType(value) {
    const uae = document.getElementById('uaeFields');
    const intl = document.getElementById('internationalFields');

    if (uae) uae.style.display = 'none';
    if (intl) intl.style.display = 'none';

    if (value === 'UAE Resident' && uae) {
        uae.style.display = 'flex';
    }

    if (value === 'International' && intl) {
        intl.style.display = 'flex';
    }
}

document.addEventListener("DOMContentLoaded", function () {
    const subtype = document.querySelector("[name$='Sub_Type__c']");
    if (subtype && subtype.value) {
        handleIndividualType(subtype.value);
    }
});

//////////////////// FILE SIZE ////////////////////
function validateFileSize(input, maxMB) {
    if (!input.files || !input.files[0]) return true;

    const fileSize = input.files[0].size / (1024 * 1024);

    if (fileSize > maxMB) {
        alert('File size must be less than ' + maxMB + ' MB');
        input.value = '';
        return false;
    }
    return true;
}

//////////////////// STEP 1 VALIDATION ////////////////////
function validateStep1() {
    let isValid = true;
    let fields = document.querySelectorAll('.agent-required');

    fields.forEach(function (field) {

        if (field.offsetParent === null) return;

        let errorSpan = field.nextElementSibling;

        if (!field.value || field.value.trim() === '') {
            field.classList.add('error-border');

            if (errorSpan) {
                errorSpan.innerText = 'This field is required';
                errorSpan.style.display = 'block';
            }

            isValid = false;
        } else {
            field.classList.remove('error-border');

            if (errorSpan) {
                errorSpan.innerText = '';
                errorSpan.style.display = 'none';
            }
        }
    });

    return isValid;
}

//////////////////// DOCUMENT VALIDATION ////////////////////
function validateDocuments() {
    let isValid = true;
    let fields = document.querySelectorAll('.agent-doc-required');

    fields.forEach(function (field) {

        if (field.offsetParent === null) return;

        let errorSpan = field.nextElementSibling;

        if (!field.value) {
            field.classList.add('error-border');

            if (errorSpan) {
                errorSpan.innerText = 'This document is required';
                errorSpan.style.display = 'block';
            }

            isValid = false;
        } else {
            field.classList.remove('error-border');

            if (errorSpan) {
                errorSpan.innerText = '';
                errorSpan.style.display = 'none';
            }
        }
    });

    return isValid;
}

//////////////////// PHONE ////////////////////
function validatePhone(input) {
    var errorDiv = document.getElementById('phoneError');

    if (/[^0-9]/.test(input.value)) {
        errorDiv.style.display = 'block';
        input.value = input.value.replace(/[^0-9]/g, '');
    } else {
        errorDiv.style.display = 'none';
    }
}

//////////////////// LOADER ////////////////////
function showLoaderOnSave() {

    if (!validateDocuments()) {
        return false;
    }

    if (!validateAllExpiryDates()) {
        return false;
    }

    var wrap = document.getElementById('saveWrapper');
    wrap.style.pointerEvents = 'none';
    wrap.style.opacity = '0.6';

    document.getElementById('loadingOverlay').style.display = 'flex';

    return true;
}

//////////////////// ✅ EMIRATES ID FORMAT (UPDATED) ////////////////////
function formatEmiratesId(el) {

    // remove all non-digits
    let val = el.value.replace(/\D/g, '');

    // 🔥 always force 784 at start
    if (!val.startsWith('784')) {
        val = '784' + val.replace(/^784/, '');
    }

    // max digits = 3 + 4 + 7 + 1 = 15
    val = val.substring(0, 15);

    let formatted = '';

    if (val.length > 0) {
        formatted = val.substring(0, 3);
    }
    if (val.length > 3) {
        formatted += '-' + val.substring(3, 7);
    }
    if (val.length > 7) {
        formatted += '-' + val.substring(7, 14);
    }
    if (val.length > 14) {
        formatted += '-' + val.substring(14);
    }

    el.value = formatted;
}
//////////////////// ✅ EXPIRY DATE VALIDATION (UPDATED) ////////////////////
function validateExpiryDate(el) {

    let value = el.value;
    if (!value) return true;

    let inputDate;

    // ✅ Handle DD/MM/YYYY (Salesforce format)
    if (value.includes('/')) {
        let parts = value.split('/'); // DD/MM/YYYY

        inputDate = new Date(parts[2], parts[1] - 1, parts[0]);
    } 
    // ✅ Handle YYYY-MM-DD (backup)
    else if (value.includes('-')) {
        let parts = value.split('-');

        inputDate = new Date(parts[0], parts[1] - 1, parts[2]);
    }

    let today = new Date();
    today.setHours(0,0,0,0);

    let container = el.closest('.slds-form-element');
    let errorEl = container ? container.querySelector('.error-message') : null;

    if (inputDate < today) {
        el.classList.add('error-border');

        if (errorEl) {
            errorEl.style.display = 'block';
            errorEl.innerText = 'Past date is not allowed';
        }

        return false;
    } else {
        el.classList.remove('error-border');

        if (errorEl) {
            errorEl.style.display = 'none';
        }

        return true;
    }
}
//////////////////// ✅ VALIDATE ALL EXPIRY ////////////////////
function validateAllExpiryDates() {
    let isValid = true;

    document.querySelectorAll('.expiry-date').forEach(function(el) {

        let result = validateExpiryDate(el);

        if (!result) {
            isValid = false;
        }
    });

    return isValid;
}
        function toggleAccountFields(value) {

    const iban = document.getElementById('ibanField');
    const swift = document.getElementById('swiftField');
    const sort = document.getElementById('sortField');
    const ifsc = document.getElementById('ifscField');

    // hide all
    iban.style.display = 'none';
    swift.style.display = 'none';
    sort.style.display = 'none';
    ifsc.style.display = 'none';

    // remove required from all
    [iban, swift, sort, ifsc].forEach(div => {
        let input = div.querySelector('input');
        if (input) input.classList.remove('bank-required');
    });

    // show + required
    if (value === 'IBAN Number') {
        iban.style.display = 'block';
        iban.querySelector('input').classList.add('bank-required');
    }
    else if (value === 'SWIFT Code') {
        swift.style.display = 'block';
        swift.querySelector('input').classList.add('bank-required');
    }
    else if (value === 'SORT Code') {
        sort.style.display = 'block';
        sort.querySelector('input').classList.add('bank-required');
    }
    else if (value === 'IFSC Code') {
        ifsc.style.display = 'block';
        ifsc.querySelector('input').classList.add('bank-required');
    }
}
    function filterTradeLicenseOptions(value) {

    const select = document.querySelector("[id$='tradeLicenseType']");
    if (!select) return;

    // original options save once
    if (!select.dataset.original) {
        let arr = [];
        for (let i = 0; i < select.options.length; i++) {
            arr.push({
                value: select.options[i].value,
                text: select.options[i].text
            });
        }
        select.dataset.original = JSON.stringify(arr);
    }

    let originalOptions = JSON.parse(select.dataset.original);

    // clear all
    select.innerHTML = '';

    originalOptions.forEach(opt => {

        if (value && value.includes('International')) {

            if (opt.text.includes('Free') || opt.text === 'Mainland') {
                return; // ❌ skip
            }
        }

        let option = document.createElement("option");
        option.value = opt.value;
        option.text = opt.text;
        select.add(option);

    });

    // auto select first
    if (select.options.length > 0) {
        select.selectedIndex = 0;
    }
}     
        document.addEventListener("DOMContentLoaded", function () {

    setTimeout(function () {

        const subtype = document.querySelector("[name$='Sub_Type__c']");
        const select = document.querySelector("[id$='tradeLicenseType']");

        if (!subtype || !select) return;

        filterTradeLicenseOptions(subtype.value);

    }, 300);

});
        
        
document.addEventListener('DOMContentLoaded', function() {
    const subTypeSelect = document.getElementById('subTypePicklist');
    const tradeLicenseSelect = document.getElementById('tradeLicensePicklist');
    
    if (subTypeSelect && tradeLicenseSelect) {
        subTypeSelect.addEventListener('change', function() {
            filterInstantly(this.value, tradeLicenseSelect);
        });
        
        // Initial filter
        filterInstantly(subTypeSelect.value, tradeLicenseSelect);
    }
});

function filterInstantly(subTypeValue, selectElement) {
    const options = selectElement.querySelectorAll('option');
    let hasDubaiOption = false;
    
    options.forEach(option => {
        if (subTypeValue && subTypeValue.toLowerCase().includes('international')) {
            // International Company → Only Dubai
            if (option.text.includes('Dubai Economic Department - Mainland')) {
                option.style.display = 'block';
                hasDubaiOption = true;
                selectElement.value = option.value;  // Auto-select
            } else {
                option.style.display = 'none';
            }
        } else {
            // Others → Show all
            option.style.display = 'block';
        }
    });
    
    // If no Dubai option found, show first available
    if (!hasDubaiOption && options.length > 0) {
        options[0].selected = true;
    }
}


