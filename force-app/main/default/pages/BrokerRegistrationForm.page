                                                      <apex:inputField value="{!agency.Company_RERA_Registration_Expiry__c}"
                                                             styleClass="slds-input agent-required expiry-date"
                                                             onchange="validateExpiryDate(this)"/>
                                        
                                            <span class="error-message"></span>
                                                
                                                        <span class="error-message"></span>
                                                        <div class="slds-form-element__help">
                                                            Format: DD/MM/YYYY
                                                        </div>
                                                    </div>
                                                </div>

                                            <div class="rera-section slds-col slds-size_1-of-3 slds-p-horizontal_small"
