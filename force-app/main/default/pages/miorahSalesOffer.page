<apex:page controller="miorahSalesOfferController"
    renderAs="pdf"
    showHeader="false"
    sidebar="false"
    applyHtmlTag="false">

<html>
<head>
    <style type="text/css">
        body {
            font-family: Arial, Helvetica, sans-serif;
            font-size: 10px;
            margin: 0;
            padding: 0;
            line-height: 1.3;
        }

        /* ===== HEADER ===== */
        .header {
            background-color: #400E06;
            color: white;
            padding: 8px 20px;
        }

        .header-table {
            width: 100%;
            border-collapse: collapse;
        }

        .header-left {
            vertical-align: top;
        }

        .header-right {
            text-align: right;
            vertical-align: top;
            font-weight: bold;
            font-size: 14px;
        }

        /* ===== CONTAINER ===== */
        .container {
            padding: 10px 20px;
        }

        .section-title {
            font-weight: bold;
            font-size: 13px;
            margin: 10px 0 5px 0;
        }

        /* ===== TABLES ===== */
        table.data-table {
            width: 100%;
            border-collapse: collapse;
            border: 1px solid #000;
            margin-bottom: 8px;
            table-layout: fixed;
        }

        table.data-table th {
            border: 1px solid #000;
            padding: 5px;
            text-align: center;
            background-color: #f2f2f2;
            font-size: 10px;
        }

        table.data-table td {
            border: 1px solid #000;
            padding: 5px;
            text-align: center;
            font-size: 10px;
            word-wrap: break-word;
        }

        .note {
            font-size: 9px;
            margin: 6px 0;
            font-weight: bold;
        }

        /* ===== FOOTER ===== */
        @page {
    size: A4;
     margin: 70px 20px 80px 20px; /* bottom space reserved for footer */

    @bottom-center {
        content: element(pdfFooter);
    }
}
        body {
                    font-family: Arial, Helvetica, sans-serif;
                    font-size: 11px;
                    color: #000;
                    margin: 0;
                    padding: 0;
                }

                .footer-container {
                    width: 100%;
                    padding: 8px 16px;
                    box-sizing: border-box;
                }

                .footer-disclaimer {
                    text-align: center;
                    font-size: 10px;
                    line-height: 1.4;
                    margin-bottom: 6px;
                }

                .footer-divider {
                    border-top: 1px solid #000;
                    margin: 6px 0;
                }

                .footer-row {
                    display: table;
                    width: 100%;
                }

                .footer-col {
                    display: table-cell;
                    vertical-align: middle;
                    font-size: 11px;
                }

                .footer-left {
                    text-align: left;
                    width: 33%;
                }

                .footer-center {
                    text-align: center;
                    width: 34%;
                }

                .footer-right {
                    text-align: right;
                    width: 33%;
                    font-weight: bold;
                }

                .footer-link {
                    color: #000;
                    text-decoration: none;
                }
    </style>
</head>

<body>

<!-- ================= HEADER ================= -->
<div class="header">
    <table class="header-table">
        <tr>
            <td class="header-left">  
               <h2 style="margin:0 0 5px 0; font-size:16px;">Details</h2>
                <b>Project Name:</b> {!projectName}<br/>
                <b>Property Type:</b> {!offer.Type__c}<br/>
                <b>Print Date:</b>
<apex:outputText value="{0,date,dd-MMM-yyyy}">
    <apex:param value="{!TODAY()}" />
</apex:outputText>
<br/>

                <b>Sales Offer Number:</b> {!offer.Name}<br/>
            </td>
            <td class="header-right">
               MIORAH BY ZOYA<br/>DEVELOPMENTS
            </td>
        </tr>
    </table>
</div>

<!-- ================= CONTENT ================= -->
<div class="container">

    <!-- PROPERTY DETAILS -->
    <div class="section-title">PROPERTY DETAILS</div>

    <table class="data-table" style="margin-top:0px;">

        <tr>
            <th>Project</th>
            <th>Unit</th>
            <th>Unit Type</th>
            <th>Selling Price (AED)</th>
            <th>Discount</th>
            <th>Discounted Price (AED)</th>
        </tr>
        <tr>
            <td>{!projectName}</td>
            <td>{!propertyName}</td>
            <td>{!offer.Type__c}</td>
            <td>
                <apex:outputText value="{0,number,#,##0.00}">
                    <apex:param value="{!offer.Original_Price__c}" />
                </apex:outputText>
            </td>
            <td>{!offer.Offer_Promotion__c}%</td>
            <td>
                <apex:outputText value="{0,number,#,##0.00}">
                    <apex:param value="{!offer.Net_Price__c}" />
                </apex:outputText>
            </td>
        </tr>
    </table>

    <div class="note">
        * APPLICABLE FEES TO DUBAI LAND DEPARTMENT ARE 4% OF THE PROPERTY NET PRICE + AED 4,200 ADMIN FEE
    </div>

    <!-- PAYMENT PLAN SUMMARY -->
    <div class="section-title">Payment plan</div>

    <table class="data-table">
        <tr>
            <th>Payments Type</th>
            <th>Date</th>
            <th>Percentage</th>
            <th>Number of Payments</th>
            <th>Payment Amount</th>
        </tr>
        <tr>
            <td>Down Payment</td>
            <td>
   			<apex:outputText value="{0,date,dd-MMM-yyyy}"><apex:param value="{!dealDate}" /></apex:outputText></td>
            <td>{!downPaymentPercent}%</td>
            <td>1</td>
            <td>
                <apex:outputText value="{0,number,#,##0.00}">
                    <apex:param value="{!downPaymentAmount}" />
                </apex:outputText>
            </td>
        </tr>
        <tr>
            <td>DLD Registration Fees</td>
           <td><apex:outputText value="{0,date,dd-MMM-yyyy}"><apex:param value="{!dealDate}" /></apex:outputText></td>
            <td>4%</td>
            <td>1</td>
            <td>
                <apex:outputText value="{0,number,#,##0.00}">
                    <apex:param value="{!dldAmount}" />
                </apex:outputText>
            </td>
        </tr>
        <tr>
            <td>Administration Fees</td>
            
            <td><apex:outputText value="{0,date,dd-MMM-yyyy}"><apex:param value="{!dealDate}" /></apex:outputText></td>
            <td>-</td>
            <td>1</td>
            <td>3500</td>
        </tr>
        <tr>
            <td><b>Total</b></td>
            <td>-</td>
            <td>-</td>
            <td>-</td>
            <td>
                <apex:outputText value="{0,number,#,##0.00}">
                    <apex:param value="{!totalPaymentAmount}" />
                </apex:outputText>
            </td>
        </tr>
    </table>

    <!-- INSTALLMENT PLAN -->
  <div class="section-title">
    PAYMENT PLAN FOR EXPECTED DEAL DATE:&nbsp;
    <apex:outputText value="{0,date,dd-MMM-yyyy}">
        <apex:param value="{!dealDate}" />
    </apex:outputText>
</div>

    <table class="data-table">
        <tr>
            <th>Installment</th>
            <th>Milestone</th>
            <th>% of Payment</th>
            <th>Amount</th>
        </tr>

        <apex:repeat value="{!installmentList}" var="row">
            <tr>
                <td>{!row.label}</td>
               <td><apex:outputText value="{0,date,dd-MMM-yyyy}"><apex:param value="{!row.milestoneDate}" /></apex:outputText></td>
                <td>{!row.percent}%</td>
                <td>
                    <apex:outputText value="{0,number,#,##0.00}">
                        <apex:param value="{!row.amount}" />
                    </apex:outputText>
                </td>
            </tr>
        </apex:repeat>
    </table>

    <!-- FOOTER -->
    <div class="footer-container">

                <!-- Disclaimer -->
                <div class="footer-disclaimer">
                    Valid for one day only from the print date. The price and payment plan are subject to change without prior notice.
                    This layout is for indicative purposes and the final layout is subject to DLD, Consultant, and Authority approvals.
                </div>

                <!-- Divider -->
                <div class="footer-divider"></div>

                <!-- Footer Row -->
                <div class="footer-row">
                    <div class="footer-col footer-left">
                        <div>Date: 14-Jan-2026</div>
                        <div>Generated By: {!recordOwnerName}</div>
                    </div>

                    <div class="footer-col footer-center">
                        <a class="footer-link" href="https://www.zoyadevelopments.ae/" target="_blank">
                            https://www.zoyadevelopments.ae/
                        </a>
                    </div>

                    <div class="footer-col footer-right">
                        {!projectName}
                    </div>
                </div>

            </div>

</div>

</body>
</html>
</apex:page>