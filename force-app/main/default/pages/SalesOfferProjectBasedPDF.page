<apex:page standardController="Sales_Offer__c"
    extensions="SalesOfferProjectBasedPDFController"
    renderAs="pdf"
    showHeader="false"
    sidebar="false"
    applyHtmlTag="false"
    action="{!setPdfFileName}">

<html>
<head>
<style type="text/css">
     body {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10px;
    margin: 0;
    padding: 0;
    line-height: 1.3;

    /* Footer space – minimal */
    padding-bottom: 60px;
}
    

  

    .header {
        background-color: #400E06;
        color: white;
        padding: 8px 20px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    .data-table {
        border: 1px solid #000;
        margin-bottom: 8px;
        table-layout: fixed;
    }

    .data-table th,
    .data-table td {
        border: 1px solid #000;
        padding: 5px;
        text-align: center;
        font-size: 10px;
    }

    .section-title {
        font-weight: bold;
        font-size: 11px;
        margin: 10px 0 5px;
    }
    
    
/* ================= PAGE SETUP ================= */
@page {
    size: A4;
    margin: 70px 20px 20px 20px; /* bottom margin kam rakho */
}

/* ================= BODY ================= */
/* 🔥 MOST IMPORTANT: footer ke liye space reserve */
    /*body {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10px;
    margin: 0;
    padding: 0;
    line-height: 1.3;

    /* Footer ki height + thoda buffer */
    padding-bottom: 120px;
}
    */
/* ================= MAIN CONTENT ================= */
.main-content {
    width: 100%;
}

/* ================= FIXED FOOTER ================= */
.footer-fixed {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;

    height: 100px;        /* footer ki actual height */
    width: 100%;
    font-size: 10px;
    background: #fff;     /* white background to avoid overlap illusion */
}

/* ================= FOOTER UI ================= */
.footer-container {
    padding: 8px 16px;
    box-sizing: border-box;
}

.footer-disclaimer {
    text-align: center;
    font-size: 10px;
    line-height: 1.4;
    margin-bottom: 6px;
}

.footer-divider {
    border-top: 1px solid #000;
    margin: 6px 0;
}

/* ================= FOOTER TABLE ================= */
/* ⚠️ Table use karo – flex / grid mat use karo */
.footer-table {
    width: 100%;
    border-collapse: collapse;
}

.footer-table td {
    font-size: 11px;
    vertical-align: middle;
    padding: 0;
}

.footer-left {
    text-align: left;
    width: 33%;
}

.footer-center {
    text-align: center;
    width: 34%;
}

.footer-right {
    text-align: right;
    width: 33%;
    font-weight: bold;
}

.footer-link {
    color: #000;
    text-decoration: none;
}

    
  
.page-break {
    page-break-before: always;
    page-break-inside: avoid;
}   
    
    /* 🔥 FORCE PAGE BREAK AFTER ROW 59 (NUV BY ZOYA STANDARD PLAN) */
.installment-table tr:nth-child(60) {
    page-break-before: always;
}

    
</style>
</head>

<body>
    
<div class="main-content">

<!-- ================================================= -->
<!-- =============== MIORAH PDF ====================== -->
<!-- ================================================= -->
<apex:outputPanel rendered="{!isMiorahProject}">

            <div class="header">
                <table class="header-table">
                    <tr>
                        <td class="header-left">
                            <h2 style="margin:0 0 5px 0; font-size:16px;">Details</h2>
                            <div style="margin-bottom:3px;"><b>Project Name:</b> {!projectName}</div>
                            <div style="margin-bottom:3px;"><b>Property Type:</b> {!propertyUnitType}</div>
                            <div style="margin-bottom:3px;">
    						<b>Print Date:&nbsp;
                                <apex:outputText value="{0,date,dd-MMM-yyyy}">
                                    <apex:param value="{!dealDate}" />
                                </apex:outputText></b>

                                <apex:outputText value="{0,date,dd-MMM-yyyy}"><apex:param value="{!offerDate}" /></apex:outputText></div>
                            <div style="margin-bottom:3px;"><b>Sales Offer Number: </b>{!offer.Name} 
                            </div>
                            
                            <div><b>Location Link: </b>https://maps.app.goo.gl/5Uf6FGqw1jzFDe7u8?g_st=iw/</div>
                        </td>
                        <td class="header-right">
                            <img src="{!$Resource.ZoyaLogo}" 
                                 style="height:150px; max-width:300px; margin-top:-40px; margin-right:-90px;"
                                 alt="Zoya Developers Logo"/>
                        </td>
                    </tr>
                </table>
            </div>

<div class="container">

    <!-- PROPERTY DETAILS -->
    <div class="section-title">PROPERTY DETAILS</div>

    <table class="data-table" style="margin-top:0px;">

        <tr>
            <th>Project</th>
            <th>Unit</th>
            <th>Unit Type</th>
             <th>Saleable Area (Sqft) </th>
            <th>Selling Price (AED)</th>
            <th>Discount</th>
            <th>Discounted Price (AED)</th>
        </tr>
        <tr>
            <td>{!projectName}</td>
            <td>{!propertyName}</td>
            <td>{!offer.Type__c}</td>
            <td>{!toalAreaSq}</td>
            <td>
                <apex:outputText value="{0,number,#,##0.00}">
                    <apex:param value="{!offer.Original_Price__c}" />
                </apex:outputText>
            </td>
            <td>{!offer.Offer_Promotion__c}%</td>
            <td>
                <apex:outputText value="{0,number,#,##0.00}">
                    <apex:param value="{!offer.Net_Price__c}" />
                </apex:outputText>
            </td>
        </tr>
    </table>

    <div class="note">
        * APPLICABLE FEES TO DUBAI LAND DEPARTMENT ARE 4% OF THE PROPERTY NET PRICE + AED 3,500 ADMIN FEE
    </div>

    <!-- PAYMENT PLAN SUMMARY -->
    <div class="section-title">Payment plan</div>

    <table class="data-table">
        <tr>
            <th>Payments Type</th>
            <th>Date</th>
            <th>Percentage</th>
            <th>Number of Payments</th>
            <th>Payment Amount</th>
        </tr>
        <tr>
            <td>Down Payment</td>
            <td>
   			<apex:outputText value="{0,date,dd-MMM-yyyy}"><apex:param value="{!dealDate}" /></apex:outputText></td>
            <td>{!downPaymentPercent}%</td>
            <td>1</td>
            <td>
                <apex:outputText value="{0,number,#,##0.00}">
                    <apex:param value="{!downPaymentAmount}" />
                </apex:outputText>
            </td>
        </tr>
        <tr>
            <td>DLD Registration Fees</td>
           <td><apex:outputText value="{0,date,dd-MMM-yyyy}"><apex:param value="{!dealDate}" /></apex:outputText></td>
            <td>4%</td>
            <td>1</td>
            <td>
                <apex:outputText value="{0,number,#,##0.00}">
                    <apex:param value="{!dldAmount}" />
                </apex:outputText>
            </td>
        </tr>
        <tr>
            <td>Administration Fees</td>
            
            <td><apex:outputText value="{0,date,dd-MMM-yyyy}"><apex:param value="{!dealDate}" /></apex:outputText></td>
            <td>-</td>
            <td>1</td>
            <td>3500</td>
        </tr>
        <tr>
            <td><b>Total</b></td>
            <td>-</td>
            <td>-</td>
            <td>-</td>
            <td>
                <apex:outputText value="{0,number,#,##0.00}">
                    <apex:param value="{!totalPaymentAmount}" />
                </apex:outputText>
            </td>
        </tr>
    </table>

    <!-- INSTALLMENT PLAN -->
  <div class="section-title">
    PAYMENT PLAN FOR EXPECTED DEAL DATE:&nbsp;
    <apex:outputText value="{0,date,dd-MMM-yyyy}">
        <apex:param value="{!dealDate}" />
    </apex:outputText>
</div>

    <table class="data-table">
        <tr>
            <th>Installment</th>
            <th>Milestone</th>
            <th>% of Payment</th>
            <th>Amount</th>
        </tr>

     <apex:repeat value="{!installmentList}" var="inst">
   <tr class="{!IF(inst.rowIndex == 21 && installmentList.size > 21, 'page-break', '')}">
        <td>{!inst.label}</td>
        <td>
            <apex:outputText value="{0,date,dd-MMM-yyyy}">
                <apex:param value="{!inst.milestoneDate}" />
            </apex:outputText>
        </td>
        <td>{!inst.percent}%</td>
        <td>
            <apex:outputText value="{0,number,#,##0.00}">
                <apex:param value="{!inst.amount}" />
            </apex:outputText>
        </td>
    </tr>
</apex:repeat>

    </table>

    <!-- FOOTER -->
   <!-- <div class="footer-container"> -->

                <!-- Disclaimer -->
             <!--   <div class="footer-disclaimer">
                    Valid for one day only from the print date. The price and payment plan are subject to change without prior notice.
                    This layout is for indicative purposes and the final layout is subject to DLD, Consultant, and Authority approvals.
                </div> -->

                <!-- Divider -->
               <!-- <div class="footer-divider"></div> -->

                <!-- Footer Row -->
               <!-- <div class="footer-row">
                    <div class="footer-col footer-left">
                        <div>Date: 14-Jan-2026</div>
                        <div>Generated By: {!recordOwnerName}</div>
                    </div>

                    <div class="footer-col footer-center">
                        <a class="footer-link" href="https://www.zoyadevelopments.ae/" target="_blank">
                            https://www.zoyadevelopments.ae/
                        </a>
                    </div>

                    <div class="footer-col footer-right">
                        {!projectName}
                    </div>
                </div>

            </div> --> 

</div>
</apex:outputPanel>

