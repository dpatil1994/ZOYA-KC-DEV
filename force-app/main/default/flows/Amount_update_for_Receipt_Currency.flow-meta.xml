    <assignments>
        <name>Assign_Currency_value_in_Amount_Currency</name>
        <label>Assign Currency value in Amount Currency</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Amount_in_Currency__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>AmountInCurrency</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Copy_1_of_Assign_Currency_value_in_Amount_Currency</name>
        <label>Copy 1 of Assign Currency value in Amount Currency</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Amount_in_Currency__c</assignToReference>
            <operator>Assign</operator>
