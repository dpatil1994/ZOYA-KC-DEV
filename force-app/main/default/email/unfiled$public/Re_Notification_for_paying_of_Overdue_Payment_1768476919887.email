<!DOCTYPE html><html> <head>  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />  <meta name="viewport" content="width=device-width, initialscale=1.0" />  <meta http-equiv="X-UA-Compatible" content="IE=edge" />  <style type="text/css">@media screen and (max-width: 480px) {slot[style] {margin-right: 0 !important;}.columnDiv {margin-right: 0 !important;}}@media screen and (min-width: 480px) {slot[style] {margin-bottom: 0 !important;}.columnDiv {margin-bottom: 0 !important;}}</style>  <style type="text/css">@media screen and (max-width: 480px) {.contentbuilderBaseColumnRow .columnCell {display:inline-block;width:100%}}</style>  <style type="text/css">.contentpageDefaultEmailTemplatePageTemplate .contentRoot {width: 600px;}@media only screen and (max-width: 480px) {.contentpageDefaultEmailTemplatePageTemplate .contentRoot {width: 320px;}}</style> </head> <body>  <table class="contentpageDefaultEmailTemplatePageTemplate" style="background-color: #E9EAEC;" role="presentation" id="contentpage_emailTemplateBodyContent" width="100%" cellpadding="0" cellspacing="0">       <tr>     <td width="100%" align="center">      <table class="contentRoot" style="background-color: #FFFFFF;" role="presentation" width="600" cellpadding="0" cellspacing="0">               <tr>         <td style="padding-top: 10px; padding-bottom: 10px; padding-left: 10px; padding-right: 10px;">          <table class="contentbuilderBaseColumnRow" style="align-items: flex-end; width: 100%; background-color:;" role="presentation" width="100%" cellpadding="0" cellspacing="0">                       <tr valign="bottom">             <td width="33.33%" class="columnCell" style="vertical-align: bottom;display: inline-block; float:left">              <div class="columnDiv" style="margin-right: 5px;margin-bottom: 5px;">               <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                                 <tr>                  <td>                   <table style="width: 100%; border-collapse: collapse; word-break: break-word; font-size: 14px" id="contentRegion" role="presentation" cellspacing="0" cellpadding="0" locked="0">                                         <tr>                      <td style="font-family: Arial, Helvetica, sans-serif;">Customer&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp;<br /><br /> P.O. Box&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :<br /><br /> Email ID&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :<br /><br /> Mobile&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;:<br /><br /> Telephone No&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :</td>                     </tr>                                       </table></td>                 </tr>                               </table>              </div></td>             <td width="33.33%" class="columnCell" style="vertical-align: bottom;display: inline-block; float:left">              <div class="columnDiv" style="margin-right: 5px;margin-bottom: 5px;">               <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                                 <tr>                  <td>                   <table style="width: 100%; border-collapse: collapse; word-break: break-word; font-size: 14px" id="contentRegion" role="presentation" cellspacing="0" cellpadding="0" locked="0">                                         <tr>                      <td style="font-family: Arial, Helvetica, sans-serif;">                       <div style="text-align: center;">                        Insert Text Here                       </div></td>                     </tr>                                       </table></td>                 </tr>                               </table>              </div></td>             <td width="33.33%" class="columnCell" style="vertical-align: bottom;display: inline-block; float:left">              <div class="columnDiv" style="margin-right: 5px;margin-bottom: 5px;">               <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                                 <tr>                  <td>                   <table style="width: 100%; border-collapse: collapse; word-break: break-word; font-size: 14px" id="contentRegion" role="presentation" cellspacing="0" cellpadding="0" locked="0">                                         <tr>                      <td style="font-family: Arial, Helvetica, sans-serif;">                       <div style="text-align: right;">                        :&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; عميل <br /><br /> :&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;صندوق بريد <br /><br /> :&nbsp; &nbsp; &nbsp; &nbsp; معرف البريد الإلكتروني <br /><br /> :&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;متحرك <br /><br /> :&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;رقم الهاتف                       </div></td>                     </tr>                                       </table></td>                 </tr>                               </table>              </div></td>            </tr>                     </table>          <table class="contentbuilderBaseColumnRow" style="align-items: flex-start; width: 100%; background-color:;" role="presentation" width="100%" cellpadding="0" cellspacing="0">                       <tr valign="top">             <td width="58.33%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <div class="columnDiv" style="margin-right: 5px;margin-bottom: 5px;">               <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                                 <tr>                  <td>                   <table style="width: 100%; border-collapse: collapse; word-break: break-word; font-size: 14px" id="contentRegion" role="presentation" cellspacing="0" cellpadding="0" locked="0">                                         <tr>                      <td style="font-family: Arial, Helvetica, sans-serif;">                       <div>                        <br /><br /><strong><span style="font-size:14px">Dear Customer,</span></strong><br /><br /><span style="line-height:1.5;"><span style="font-size:14px;"><span style="font-family:Calibri"><span style="font-family:Calibri">Reference</span>&nbsp;<span style="font-family:Calibri">to</span>&nbsp;<span style="font-family:Calibri">[Sale</span>&nbsp;<span style="font-family:Calibri">and</span>&nbsp;<span style="font-family:Calibri">Purchase</span>&nbsp;<span style="font-family:Calibri">Agreement</span>&nbsp;<span style="font-family:Calibri">/</span>&nbsp;<span style="font-family:Calibri">Unit</span><span style="font-family:Calibri">Reservation&nbsp;Contract] Dated&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;between us,<br /> concerning Unit No.&nbsp;<br /> Project&nbsp;</span><b><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold">{{{Opportunity.Project_Name__c}}}</span></span>&nbsp;</b><br /><span style="font-family:Calibri">in&nbsp;Dubai(“the</span>&nbsp;<b><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold">Contract</span></span></b><span style="font-family:Calibri"><font face="Calibri">”)</font></span>&nbsp;<span style="font-family:Calibri">The</span>&nbsp;<span style="font-family:Calibri">current</span>&nbsp;<span style="font-family:Calibri">percentage</span>&nbsp;<span style="font-family:Calibri">of</span>&nbsp;<span style="font-family:Calibri">this</span>&nbsp;<br /><span style="font-family:Calibri">project</span>&nbsp;<span style="font-family:Calibri">is&nbsp;</span><b><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold">15.05</span></span></b></span></span></span>                       </div></td>                     </tr>                                       </table></td>                 </tr>                               </table>              </div></td>             <td width="41.66%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <div class="columnDiv" style="margin-right: 5px;margin-bottom: 5px;">               <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                                 <tr>                  <td>                   <table style="width: 100%; border-collapse: collapse; word-break: break-word; font-size: 14px" id="contentRegion" role="presentation" cellspacing="0" cellpadding="0" locked="0">                                         <tr>                      <td style="font-family: Arial, Helvetica, sans-serif;">                       <div style="text-align: right;">                        <br /><br /><strong>عزيزي العميل،</strong><br /><br /><span style="line-height:1.5;"><span style="font-size:14px">إشارة إلى اتفاقية البيع والشراء / عقد حجز الوحدة<br /><span style="font-family:Calibri"><span style="font-family:Calibri"><font face="Calibri">ﺑﺎﻟﻮﺣﺪ</font><font face="Arial, Helvetica, sans-serif">ة</font></span>&nbsp;<span style="font-family:Calibri"><font face="Calibri">ﻳﺘﻌﻠﻖ</font></span>&nbsp;<span style="font-family:Calibri"><font face="Calibri">ﻓﻴﻤﺎ</font></span>&nbsp;<b>&nbsp;&nbsp;</b><b>&nbsp;</b><span style="font-family:Calibri"><font face="Calibri">ﺑﺘﺎ</font><font face="Arial, Helvetica, sans-serif">ر</font><font face="Calibri">ﻳﺦ</font></span>&nbsp;<span style="font-family:Calibri"><font face="Calibri">ﺑﻴﻨﻨﺎ</font></span>&nbsp;<span style="font-family:Calibri">ا<font face="Calibri">ﻟﻤﺒﺮ</font><font face="Arial, Helvetica, sans-serif">م</font></span>&nbsp;</span><br /><span style="font-family:Calibri"><span style="font-family:Calibri"><font face="Calibri">ﻣﺸﺮ</font><font face="Arial, Helvetica, sans-serif">وع</font></span>&nbsp;<span style="font-family:Calibri"><font face="Calibri">ﺿﻤﻦ</font></span>&nbsp;<b>&nbsp;</b><span style="font-family:Calibri">ر<font face="Calibri">ﻗﻢ</font></span>&nbsp;<span style="font-family:Calibri">بريستين من زويا</span>&nbsp;</span><br /><span style="font-family:Calibri">&nbsp;<b><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold">("</span></span></b><b>&nbsp;</b><b><span style="font-family:Arial"><span style="font-weight:bold">اﻟﻌﻘﺪ</span></span></b><b>&nbsp;</b><b><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold">")</span></span></b><b>&nbsp;</b><span style="font-family:Calibri">د<font face="Calibri">ﺑﻲ</font></span>&nbsp;<span style="font-family:Calibri"><font face="Calibri">ﻓﻲ</font></span>&nbsp;<span style="font-family:Calibri">ا<font face="Calibri">ﻟﻜﺎﺋﻦ</font></span>&nbsp;<b><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold">"</span></span></b></span><br /> تبلغ النسبة المئوية الحالية لهذا المشروع 15.05</span></span><br /> &nbsp;                       </div></td>                     </tr>                                       </table></td>                 </tr>                               </table>              </div></td>            </tr>                     </table>          <table class="contentbuilderBaseColumnRow" style="align-items: flex-start; width: 100%; background-color:;" role="presentation" width="100%" cellpadding="0" cellspacing="0">                       <tr valign="top">             <td width="58.33%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                               <tr>                 <td>                  <table style="width: 100%; border-collapse: collapse; word-break: break-word; font-size: 14px" id="contentRegion" role="presentation" cellspacing="0" cellpadding="0" locked="0">                                       <tr>                     <td style="font-family: Arial, Helvetica, sans-serif;"><br /><span style="line-height:1.5;"><span style="font-size:14px;"><span style="font-family:Calibri"><span style="font-family:Calibri">Please note that you are in default in payment of purchase price&nbsp;as per the payment schedule in the Contract. As per the Dubai&nbsp;Land Department rules and regulations as well as per the&nbsp;Contract, you shall be liable to pay the </span><b><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold">37.05 % </span></span></b><span style="font-family:Calibri">having a total&nbsp;amount of </span><b><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold">AED 611,325.00 </span></span></b><span style="font-family:Calibri">from the Unit purchase price,&nbsp;therefore we serve you this legal notice to settle the&nbsp;outstanding amount within </span><b><u><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold"><span style="text-decoration:underline">(30) days</span></span></span></u></b><b>&nbsp;</b><span style="font-family:Calibri">from date of Serving this&nbsp;Legal</span>&nbsp;<span style="font-family:Calibri"><span style="letter-spacing:-0.1000pt">Notice.</span></span></span></span></span></td>                    </tr>                                     </table></td>                </tr>                             </table></td>             <td width="41.66%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                               <tr>                 <td>                  <table style="width: 100%; border-collapse: collapse; word-break: break-word; font-size: 14px" id="contentRegion" role="presentation" cellspacing="0" cellpadding="0" locked="0">                                       <tr>                     <td style="font-family: Arial, Helvetica, sans-serif;">                      <div style="text-align: right;">                       <br /><span style="font-size:16px;">يرجى العلم بأنك متخلف عن سداد ثمن الشراء وفقًا لجدول الدفعات الوارد في العقد. ووفقًا لقواعد وأنظمة دائرة الأراضي والأملاك في دبي، وكذلك وفقًا للعقد، فأنت ملزم بدفع نسبة 37.05%، أي ما مجموعه 611,325.00 درهمًا إماراتيًا، من ثمن شراء الوحدة. لذا، نوجه إليك هذا الإشعار القانوني لتسوية المبلغ المستحق خلال (30) يومًا من تاريخ هذا الإشعار.</span>                      </div></td>                    </tr>                                     </table></td>                </tr>                             </table></td>            </tr>                     </table>          <table class="contentbuilderBaseColumnRow" style="align-items: flex-start; width: 100%; background-color:;" role="presentation" width="100%" cellpadding="0" cellspacing="0">                       <tr valign="top">             <td width="58.33%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <div class="columnDiv" style="margin-right: 5px;margin-bottom: 5px;">               <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                                 <tr>                  <td>                   <table style="width: 100%; border-collapse: collapse; word-break: break-word; font-size: 14px" id="contentRegion" role="presentation" cellspacing="0" cellpadding="0" locked="0">                                         <tr>                      <td style="font-family: Arial, Helvetica, sans-serif;"><br /><span style="line-height:1.5;"><span style="font-size:14px;"><span style="font-family:Calibri"><span style="font-family:Calibri">Should you fail to pay the full outstanding amount within the&nbsp;timescales set out above otherwise we will proceed to the&nbsp;judicial procedures, we hereby reserve our rights under&nbsp; the&nbsp;Contract,</span>&nbsp;<span style="font-family:Calibri">and</span>&nbsp;<span style="font-family:Calibri">to</span>&nbsp;<span style="font-family:Calibri">commence</span>&nbsp;<span style="font-family:Calibri">legal<br /> proceedings</span>&nbsp;<span style="font-family:Calibri">as</span>&nbsp;<span style="font-family:Calibri">per</span>&nbsp;<span style="font-family:Calibri"><span style="letter-spacing:-0.2000pt">Dubai Laws/ UAE including law No. (13) / 2008 and its amendments and resolution of the Executive Council No. (6) in 2010.&nbsp;</span></span></span></span></span><br /><br /><br /> &nbsp;</td>                     </tr>                                       </table></td>                 </tr>                               </table>              </div></td>             <td width="41.66%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <div class="columnDiv" style="margin-right: 5px;margin-bottom: 5px;">               <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                                 <tr>                  <td>                   <table style="width: 100%; border-collapse: collapse; word-break: break-word; font-size: 14px" id="contentRegion" role="presentation" cellspacing="0" cellpadding="0" locked="0">                                         <tr>                      <td style="font-family: Arial, Helvetica, sans-serif;">                       <div style="text-align: right;">                        <br /><span style="font-size:14px;"><span style="line-height:1.5;">في حال عدم سدادكم كامل المبلغ المستحق خلال<br /> المدة المحددة أعلاه، وإلا سنلجأ إلى الإجراءات القضائية، فإننا نحتفظ بحقوقنا بموجب هذا العقد، وفي بدء الإجراءات القانونية<br /> وفقاً لقوانين دبي/ دولة الإمارات العربية المتحدة، بما في ذلك القانون رقم (13) لسنة 2008 وتعديلاته وقرار المجلس التنفيذي رقم (6) لسنة 2010.</span></span>                       </div></td>                     </tr>                                       </table></td>                 </tr>                               </table>              </div></td>            </tr>                     </table>          <table class="contentbuilderBaseColumnRow" style="align-items: flex-start; width: 100%; background-color:;" role="presentation" width="100%" cellpadding="0" cellspacing="0">                       <tr valign="top">             <td width="50%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <div class="columnDiv" style="margin-right: 5px;margin-bottom: 5px;">               <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                                 <tr>                  <td>                   <table style="width: 100%; border-collapse: collapse; word-break: break-word; font-size: 14px" id="contentRegion" role="presentation" cellspacing="0" cellpadding="0" locked="0">                                         <tr>                      <td style="font-family: Arial, Helvetica, sans-serif;"><br /><u><span style="tab-stops:left blank 287.1000pt "><b><span style="font-size:9.5000pt"><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold"><span style="text-decoration:underline"><span style="text-underline:single">If</span></span></span></span></span></b><b>&nbsp;</b><b><span style="font-size:9.5000pt"><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold"><span style="text-decoration:underline"><span style="text-underline:single">you</span></span></span></span></span></b><b>&nbsp;</b><b><span style="font-size:9.5000pt"><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold"><span style="text-decoration:underline"><span style="text-underline:single">have</span></span></span></span></span></b><b>&nbsp;</b><b><span style="font-size:9.5000pt"><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold"><span style="text-decoration:underline"><span style="text-underline:single">already</span></span></span></span></span></b><b>&nbsp;</b><b><span style="font-size:9.5000pt"><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold"><span style="text-decoration:underline"><span style="text-underline:single">made</span></span></span></span></span></b><b>&nbsp;</b><b><span style="font-size:9.5000pt"><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold"><span style="text-decoration:underline"><span style="text-underline:single">the</span></span></span></span></span></b><b>&nbsp;</b><b><span style="font-size:9.5000pt"><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold"><span style="text-decoration:underline"><span style="text-underline:single">overdue</span></span></span></span></span></b><b>&nbsp;</b><b><span style="font-size:9.5000pt"><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold"><span style="text-decoration:underline"><span style="text-underline:single">payment,</span></span></span></span></span></b><b>&nbsp;</b><b><span style="letter-spacing: -0.1pt;"><span style="font-weight: bold;"><font face="Trebuchet MS"><span style="font-size: 9.5pt;">please</span></font>&nbsp;</span></span></b></span><span style="font-size:11pt"><span style="line-height:107%"><span style="font-family:Calibri"><b><span style="font-size:9.5000pt"><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold"><span style="text-decoration:underline"><span style="text-underline:single">ignore</span></span></span></span></span></b><b>&nbsp;</b><b><span style="font-size:9.5000pt"><span style="font-family:'Trebuchet MS'"><span style="font-weight:bold"><span style="text-decoration:underline"><span style="text-underline:single">this</span></span></span></span></span></b><b>&nbsp;</b><b><span style="font-size:9.5000pt"><span style="font-family:'Trebuchet MS'"><span style="letter-spacing:-0.1000pt"><span style="font-weight:bold"><span style="text-decoration:underline"><span style="text-underline:single">Notification.</span></span></span></span></span></span></b></span></span></span></u></td>                     </tr>                                       </table></td>                 </tr>                               </table>              </div></td>             <td width="50%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <div class="columnDiv" style="margin-right: 5px;margin-bottom: 5px;">               <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                                 <tr>                  <td>                   <table style="width: 100%; border-collapse: collapse; word-break: break-word; font-size: 14px" id="contentRegion" role="presentation" cellspacing="0" cellpadding="0" locked="0">                                         <tr>                      <td style="font-family: Arial, Helvetica, sans-serif;">                       <div style="text-align: right;">                        <br /><u><strong>إذا كنت قد قمت بالفعل بسداد المبلغ المتأخر، فيرجى<br /> تجاهل هذا الإشعار.</strong></u>                       </div></td>                     </tr>                                       </table></td>                 </tr>                               </table>              </div></td>            </tr>                     </table>          <table class="contentbuilderBaseColumnRow" style="align-items: flex-start; width: 100%; background-color:;" role="presentation" width="100%" cellpadding="0" cellspacing="0">                       <tr valign="top">             <td width="58.33%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <div class="columnDiv" style="margin-right: 5px;margin-bottom: 5px;">               <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                                 <tr>                  <td>                   <table style="width: 100%; border-collapse: collapse; word-break: break-word; font-size: 14px" id="contentRegion" role="presentation" cellspacing="0" cellpadding="0" locked="0">                                         <tr>                      <td style="font-family: Arial, Helvetica, sans-serif;"><br /><br /><span style="font-size:16px;"><span style="font-family:Calibri"><span style="font-family:Calibri">Payment should be made payable to the&nbsp;below&nbsp; account&nbsp;number,</span>&nbsp;<span style="font-family:Calibri">please</span>&nbsp;<span style="font-family:Calibri">also</span>&nbsp;<span style="font-family:Calibri">include</span>&nbsp;<span style="font-family:Calibri">your</span>&nbsp;<span style="font-family:Calibri">full</span>&nbsp;<span style="font-family:Calibri">name&nbsp;</span><span style="font-family:Calibri">and</span>&nbsp;<span style="font-family:Calibri">apartment</span>&nbsp;<span style="font-family:Calibri">number on the bank transfer document.</span></span></span></td>                     </tr>                                       </table></td>                 </tr>                               </table>              </div></td>             <td width="41.66%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <div class="columnDiv" style="margin-right: 5px;margin-bottom: 5px;">               <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                                 <tr>                  <td>                   <table style="width: 100%; border-collapse: collapse; word-break: break-word; font-size: 14px" id="contentRegion" role="presentation" cellspacing="0" cellpadding="0" locked="0">                                         <tr>                      <td style="font-family: Arial, Helvetica, sans-serif;">          