<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Receipt_Date_Not_Future</fullName>
    <active>true</active>
    <errorConditionFormula>Receipt_Date__c &gt; TODAY()</errorConditionFormula>
    <errorDisplayField>Receipt_Date__c</errorDisplayField>
    <errorMessage>Receipt Date cannot be a future date.</errorMessage>
</ValidationRule>
