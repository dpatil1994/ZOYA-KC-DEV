<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>If_Status_is_Completed_Verified</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT(ISNEW()),
    ISCHANGED(Status),
    ISPICKVAL(PRIORVALUE(Status), &quot;Completed / Verified&quot;)
)</errorConditionFormula>
    <errorMessage>This record is Completed/Verified and cannot be modified.</errorMessage>
</ValidationRule>
