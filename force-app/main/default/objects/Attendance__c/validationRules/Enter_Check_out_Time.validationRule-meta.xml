<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Enter_Check_out_Time</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT(ISBLANK( Check_in_Time__c )),
    ISBLANK( Check_out_Time__c )
)</errorConditionFormula>
    <errorDisplayField>Check_out_Time__c</errorDisplayField>
    <errorMessage>Please enter Check-out Time.</errorMessage>
</ValidationRule>
