<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Birthdate_should_not_be_future_date</fullName>
    <active>true</active>
    <errorConditionFormula>PersonBirthdate &gt; TODAY()</errorConditionFormula>
    <errorDisplayField>PersonBirthdate</errorDisplayField>
    <errorMessage>Birth date cannot be a future date.</errorMessage>
</ValidationRule>
