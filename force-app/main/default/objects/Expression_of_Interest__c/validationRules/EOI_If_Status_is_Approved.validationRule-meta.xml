<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>EOI_If_Status_is_Approved</fullName>
    <active>true</active>
    <description>If Status is Approved then only Finance Team can change the record.</description>
    <errorConditionFormula>AND(
    NOT(ISNEW()),
    TEXT(PRIORVALUE(Status__c)) = &quot;Verified&quot;,
    $User.Username &lt;&gt; &quot;noumanahmed159@gmail.com.kcdev&quot;
)</errorConditionFormula>
    <errorMessage>This record is Verified and cannot be modified.</errorMessage>
</ValidationRule>
