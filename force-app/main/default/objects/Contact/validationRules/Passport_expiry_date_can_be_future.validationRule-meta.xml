<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Passport_expiry_date_can_be_future</fullName>
    <active>true</active>
    <errorConditionFormula>Passport_Expiry_Date__c &lt; TODAY()</errorConditionFormula>
    <errorDisplayField>Passport_Expiry_Date__c</errorDisplayField>
    <errorMessage>Passport Expiry Date cannot be backdate</errorMessage>
</ValidationRule>
