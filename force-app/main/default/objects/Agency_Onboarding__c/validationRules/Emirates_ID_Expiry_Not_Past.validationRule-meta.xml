<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Emirates_ID_Expiry_Not_Past</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT(ISBLANK(Emirates_ID_Expiry_Date__c)),
    Emirates_ID_Expiry_Date__c &lt; TODAY()
)</errorConditionFormula>
    <errorDisplayField>Emirates_ID_Expiry_Date__c</errorDisplayField>
    <errorMessage>Emirates ID Expiry Date cannot be in the past</errorMessage>
</ValidationRule>
