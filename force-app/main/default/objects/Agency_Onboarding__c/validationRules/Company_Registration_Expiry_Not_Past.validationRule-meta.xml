<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Company_Registration_Expiry_Not_Past</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT(ISBLANK(Company_Registration_Expiry_Date__c)),
    Company_Registration_Expiry_Date__c &lt; TODAY()
)</errorConditionFormula>
    <errorDisplayField>Company_Registration_Expiry_Date__c</errorDisplayField>
    <errorMessage>Company Registration Expiry Date cannot be in the past</errorMessage>
</ValidationRule>
